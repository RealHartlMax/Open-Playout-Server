<Window x:Class="PlayoutServer.GUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PlayoutServer.GUI"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Menu Grid.Row="0">
            <MenuItem Header="Einstellungen">
                <MenuItem Header="Verbindung..." Click="OpenSettings_Click" />
            </MenuItem>
        </Menu>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="10" VerticalAlignment="Center">
            <TextBlock Text="Status: " VerticalAlignment="Center"/>
            <TextBlock x:Name="StatusText" Text="Getrennt" VerticalAlignment="Center" Margin="5,0"/>
            <Button x:Name="ConnectButton" Content="Verbinden" Click="ConnectButton_Click" Margin="10,0"/>
            <Button Content="▶ Play" Click="PlayButton_Click" Margin="10,0"/>
            <Button Content="■ Stop" Click="StopButton_Click" Margin="10,0"/>
            <Button Content="⏭ Next" Click="SkipButton_Click" Margin="10,0"/>
            <Button Content="📋 Playlist" Click="OpenPlaylistEditor_Click" Margin="10,0" Background="#7c3aed" Foreground="White"/>
        </StackPanel>

        <Grid Grid.Row="2" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <ListBox x:Name="EventsList" Grid.Column="0" Margin="0,0,10,0"/>

            <Border x:Name="SettingsPanel" Grid.Column="1" BorderBrush="Gray" BorderThickness="1" CornerRadius="4" Padding="8" Background="#1f2937">
                <StackPanel>
                    <TextBlock Text="Verbindungseinstellungen" FontWeight="Bold" Margin="0,0,0,8" Foreground="White" />
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="Host" Width="50" VerticalAlignment="Center" Foreground="White" />
                        <TextBox x:Name="HostTextBox" Width="150" Text="localhost" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="Port" Width="50" VerticalAlignment="Center" Foreground="White" />
                        <TextBox x:Name="PortTextBox" Width="150" Text="5000" />
                    </StackPanel>
                    <TextBlock Text="Streamer.bot" FontWeight="Bold" Margin="0,12,0,6" Foreground="#88ccff" />
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="Host" Width="50" VerticalAlignment="Center" Foreground="White" />
                        <TextBox x:Name="StreamerbotHostTextBox" Width="150" Text="localhost" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="Port" Width="50" VerticalAlignment="Center" Foreground="White" />
                        <TextBox x:Name="StreamerbotPortTextBox" Width="150" Text="8081" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="Pass" Width="50" VerticalAlignment="Center" Foreground="White" />
                        <PasswordBox x:Name="StreamerbotPasswordBox" Width="150" />
                    </StackPanel>
                    <Button Content="Speichern" Click="SaveSettings_Click" Margin="0,8,0,0" />
                    <TextBlock x:Name="SettingsStatus" Text="" Foreground="#88ff88" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
