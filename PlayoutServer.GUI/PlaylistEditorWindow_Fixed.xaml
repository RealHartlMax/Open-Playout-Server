<Window x:Class="PlayoutServer.GUI.PlaylistEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Playlist Editor" Height="500" Width="600"
        WindowStartupLocation="CenterOwner"
        Background="#111827">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#1f2937" Padding="10">
            <TextBlock Text="Playlist Reordnen - Drag + Drop" FontSize="14" FontWeight="Bold" Foreground="White"/>
        </Border>

        <!-- ListBox mit Drag and Drop -->
        <ListBox x:Name="PlaylistListBox" Grid.Row="1" Margin="10" Background="#1e293b" Foreground="White" AllowDrop="True"
                 PreviewMouseLeftButtonDown="PlaylistListBox_PreviewMouseLeftButtonDown"
                 PreviewMouseMove="PlaylistListBox_PreviewMouseMove"
                 Drop="PlaylistListBox_Drop">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Padding="8" Margin="0,2" Background="#334155" CornerRadius="4" 
                            MouseEnter="ItemBorder_MouseEnter" MouseLeave="ItemBorder_MouseLeave">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="White"/>
                                <TextBlock Text="{Binding Duration, StringFormat='Laenge: {0}s'}" Foreground="#cbd5e1" FontSize="11"/>
                            </StackPanel>

                            <Button Grid.Column="1" Content="X Del" Click="DeleteButton_Click" Tag="{Binding Name}"
                                    Padding="8,4" Margin="10,0,0,0" Background="#dc2626" Foreground="White"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Footer Buttons -->
        <Border Grid.Row="2" Background="#1f2937" Padding="10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Abbrechen" Click="CancelButton_Click" Padding="10,6" Margin="5" Background="#475569" Foreground="White"/>
                <Button Content="Speichern" Click="SaveButton_Click" Padding="10,6" Margin="5" Background="#16a34a" Foreground="White"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
