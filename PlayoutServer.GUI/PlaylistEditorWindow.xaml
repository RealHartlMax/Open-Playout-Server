<Window x:Class="PlayoutServer.GUI.PlaylistEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Playlist Editor" Height="700" Width="900"
        WindowStartupLocation="CenterOwner"
        Background="#111827"
        Foreground="#e2e8f0"
        ResizeMode="CanResizeWithGrip">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#7c3aed" Padding="15">
            <TextBlock Text="📋 Playlist Editor" FontSize="18" FontWeight="Bold" Foreground="White"/>
        </Border>

        <!-- Toolbar -->
        <Border Grid.Row="1" Background="#1f2937" Padding="10" BorderBrush="#334155" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <Button Content="➕ Video hinzufügen" Click="AddMediaButton_Click" 
                        Padding="10,6" Background="#10b981" Foreground="White" FontWeight="Bold" Margin="0,0,5,0"/>
                <Button Content="💾 Exportieren" Click="ExportButton_Click" 
                        Padding="10,6" Background="#3b82f6" Foreground="White" FontWeight="Bold" Margin="5,0"/>
                <Button Content="📂 Importieren" Click="ImportButton_Click" 
                        Padding="10,6" Background="#f59e0b" Foreground="White" FontWeight="Bold" Margin="5,0"/>
                <Button Content="🗑️ Entfernen" Click="RemoveButton_Click" 
                        Padding="10,6" Background="#dc2626" Foreground="White" FontWeight="Bold" Margin="5,0"/>
                <Separator Width="1" Background="#475569" Margin="10,0"/>
                <TextBlock x:Name="StatusText" VerticalAlignment="Center" Foreground="#94a3b8" FontSize="12" Margin="5,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Playlist ListBox -->
        <ListBox x:Name="PlaylistListBox" Grid.Row="2" Margin="10" Background="#1e293b" Foreground="White" AllowDrop="True"
                 PreviewMouseLeftButtonDown="PlaylistListBox_PreviewMouseLeftButtonDown"
                 PreviewMouseMove="PlaylistListBox_PreviewMouseMove"
                 Drop="PlaylistListBox_Drop"
                 PreviewDrop="PlaylistListBox_PreviewDrop">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Padding="12" Margin="0,4" Background="#334155" CornerRadius="6" 
                            MouseEnter="ItemBorder_MouseEnter" MouseLeave="ItemBorder_MouseLeave">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Thumbnail -->
                            <Border Grid.Column="0" Background="#1e293b" CornerRadius="4" Width="50" Height="40" Margin="0,0,10,0">
                                <TextBlock Text="🎬" FontSize="24" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Border>

                            <!-- Info -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="White" FontSize="13"/>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock Text="{Binding Duration, StringFormat='⏱️ {0}s'}" Foreground="#cbd5e1" FontSize="11" Margin="0,0,15,0"/>
                                    <TextBlock Text="{Binding StreamerbotStatus}" Foreground="#cbd5e1" FontSize="11" Margin="0,0,15,0"/>
                                    <TextBlock Text="{Binding FilePath, StringFormat='📄 {0}'}" Foreground="#94a3b8" FontSize="10" Margin="0,0,0,0"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Action Buttons -->
                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Content="⚙️" Click="ConfigButton_Click" Tag="{Binding Name}"
                                        Padding="8,4" Background="#2563eb" Foreground="White" FontSize="12" Margin="0,0,3,0"/>
                                <Button Content="✕" Click="DeleteButton_Click" Tag="{Binding Name}"
                                        Padding="8,4" Background="#dc2626" Foreground="White" FontSize="12"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Empty State -->
        <TextBlock x:Name="EmptyStateText" Grid.Row="2" Text="👀 Keine Videos in der Playlist&#10;Klicke &quot;Video hinzufügen&quot; um zu beginnen" 
                   TextAlignment="Center" VerticalAlignment="Center" Foreground="#94a3b8" FontSize="13" 
                   Visibility="Collapsed"/>

        <!-- Footer Buttons -->
        <Border Grid.Row="3" Background="#1f2937" Padding="10" BorderBrush="#334155" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Abbrechen" Click="CancelButton_Click" Padding="12,8" Background="#475569" Foreground="White" FontWeight="Bold" MinWidth="100" Margin="0,0,5,0"/>
                <Button Content="✓ Speichern" Click="SaveButton_Click" Padding="12,8" Background="#16a34a" Foreground="White" FontWeight="Bold" MinWidth="100"/>
            </StackPanel>
        </Border>

        <!-- Modal Overlay: Add Media -->
        <Grid x:Name="AddMediaModal" Grid.Row="0" Grid.RowSpan="4" Background="#00000099" Opacity="0" IsHitTestVisible="False" Panel.ZIndex="1000" Visibility="Collapsed">
            <Border Background="#1f2937" CornerRadius="8" Padding="20" MaxWidth="500" VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="📁 Video hinzufügen" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,0,0,15"/>
                    
                    <Border Background="#111827" CornerRadius="6" MaxHeight="300" Margin="0,0,0,15" Padding="10">
                        <StackPanel x:Name="AddMediaGrid">
                            <!-- Media items werden hier eingefügt -->
                        </StackPanel>
                    </Border>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                        <Button Content="Abbrechen" Click="CloseAddMediaModal_Click" Padding="10,6" Background="#475569" Foreground="White"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Modal Overlay: Streamer.bot Config -->
        <Grid x:Name="ConfigModal" Grid.Row="0" Grid.RowSpan="4" Background="#00000099" Opacity="0" IsHitTestVisible="False" Panel.ZIndex="1000" Visibility="Collapsed">
            <Border Background="#1f2937" CornerRadius="8" Padding="20" MaxWidth="400" VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel>
                    <TextBlock x:Name="ConfigModalTitle" Text="Video-Konfiguration" FontSize="14" FontWeight="Bold" Foreground="White" Margin="0,0,0,15"/>
                    
                    <CheckBox x:Name="EnableStreamerbotCheck" Content="An Streamer.bot senden" 
                              Foreground="White" Margin="0,0,0,10" Checked="EnableStreamerbot_Changed" Unchecked="EnableStreamerbot_Changed"/>

                    <StackPanel x:Name="StreamerbotOptionsPanel" Visibility="Collapsed" Margin="0,0,0,15">
                        <TextBlock Text="Metadaten zum Übertragen:" Foreground="#cbd5e1" FontSize="11" Margin="0,0,0,8"/>
                        <CheckBox x:Name="MetaTitleCheck" Content="Titel" Foreground="#cbd5e1" Margin="0,0,0,5"/>
                        <CheckBox x:Name="MetaDurationCheck" Content="Dauer" Foreground="#cbd5e1" Margin="0,0,0,5"/>
                        <CheckBox x:Name="MetaFilenameCheck" Content="Dateiname" Foreground="#cbd5e1" Margin="0,0,0,5"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                        <Button Content="Abbrechen" Click="CloseConfigModal_Click" Padding="10,6" Background="#475569" Foreground="White" Margin="0,0,5,0"/>
                        <Button Content="✓ Speichern" Click="SaveConfigModal_Click" Padding="10,6" Background="#16a34a" Foreground="White"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
