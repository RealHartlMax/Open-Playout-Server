@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Playlist Editor - PlayoutServer</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);
            color: #e2e8f0;
            min-height: 100vh;
            padding: 20px;
        }

        .container {
            max-width: 800px;
            margin: 0 auto;
            background: #1f2937;
            border-radius: 12px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
            overflow: hidden;
        }

        .header {
            background: linear-gradient(135deg, #7c3aed 0%, #6d28d9 100%);
            padding: 20px;
            text-align: center;
        }

        .header h1 {
            font-size: 28px;
            margin-bottom: 5px;
        }

        .header p {
            opacity: 0.9;
            font-size: 14px;
        }

        .content {
            padding: 20px;
            max-height: 600px;
            overflow-y: auto;
        }

        .playlist-list {
            list-style: none;
        }

        .playlist-item {
            background: #334155;
            padding: 15px;
            margin-bottom: 8px;
            border-radius: 8px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            cursor: move;
            transition: all 0.2s ease;
            border-left: 4px solid #7c3aed;
        }

        .playlist-item:hover {
            background: #475569;
            transform: translateX(4px);
        }

        .playlist-item.dragging {
            opacity: 0.5;
            background: #1e293b;
        }

        .playlist-item.drag-over {
            border-top: 3px solid #7c3aed;
        }

        .item-info h3 {
            font-size: 16px;
            margin-bottom: 4px;
        }

        .item-info p {
            font-size: 12px;
            opacity: 0.7;
        }

        .item-actions {
            display: flex;
            gap: 8px;
        }

        .btn {
            padding: 8px 12px;
            border: none;
            border-radius: 6px;
            cursor: pointer;
            font-size: 12px;
            font-weight: 600;
            transition: all 0.2s ease;
        }

        .btn-delete {
            background: #dc2626;
            color: white;
        }

        .btn-delete:hover {
            background: #b91c1c;
            transform: scale(1.05);
        }

        .btn-up {
            background: #2563eb;
            color: white;
        }

        .btn-up:hover {
            background: #1d4ed8;
        }

        .btn-down {
            background: #2563eb;
            color: white;
        }

        .btn-down:hover {
            background: #1d4ed8;
        }

        .footer {
            background: #111827;
            padding: 20px;
            display: flex;
            justify-content: space-between;
            gap: 10px;
        }

        .btn-primary {
            background: #16a34a;
            color: white;
            padding: 10px 20px;
            flex: 1;
        }

        .btn-primary:hover {
            background: #15803d;
        }

        .btn-secondary {
            background: #475569;
            color: white;
            padding: 10px 20px;
            flex: 1;
        }

        .btn-secondary:hover {
            background: #64748b;
        }

        .status {
            text-align: center;
            padding: 10px;
            font-size: 12px;
            opacity: 0.7;
        }

        .status.loading::after {
            content: " ...";
            animation: dots 1.5s steps(4, end) infinite;
        }

        @@keyframes dots {
            0%, 20% { content: " ."; }
            40% { content: " .."; }
            60%, 100% { content: " ..."; }
        }

        .empty-state {
            text-align: center;
            padding: 40px 20px;
            color: #94a3b8;
        }

        .empty-state p {
            font-size: 14px;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>📋 Playlist Editor</h1>
            <p>Drag & Drop zum Reordnen, Delete zum Löschen</p>
        </div>

        <div class="content">
            <div id="status" class="status loading">Playlist wird geladen</div>
            <ul id="playlistList" class="playlist-list"></ul>
            <div id="emptyState" class="empty-state" style="display: none;">
                <p>👀 Keine Videos in der Playlist</p>
            </div>
        </div>

        <div class="footer">
            <button class="btn btn-secondary" onclick="closeEditor()">Abbrechen</button>
            <button class="btn btn-primary" onclick="savePlaylist()">✓ Speichern</button>
        </div>
    </div>

    <script>
        let playlistItems = [];
        let draggedIndex = -1;

        async function loadPlaylist() {
            try {
                const response = await fetch('/api/playout/playlist');
                const data = await response.json();
                playlistItems = data.playlist || [];
                renderPlaylist();
                document.getElementById('status').style.display = 'none';
            } catch (error) {
                document.getElementById('status').innerHTML = '❌ Fehler beim Laden: ' + error.message;
                console.error('Fehler:', error);
            }
        }

        function renderPlaylist() {
            const list = document.getElementById('playlistList');
            const empty = document.getElementById('emptyState');
            
            list.innerHTML = '';
            
            if (playlistItems.length === 0) {
                empty.style.display = 'block';
                return;
            }
            
            empty.style.display = 'none';
            
            playlistItems.forEach((item, index) => {
                const li = document.createElement('li');
                li.className = 'playlist-item';
                li.draggable = true;
                li.dataset.index = index;
                
                li.innerHTML = `
                    <div class="item-info">
                        <h3>${escapeHtml(item.name)}</h3>
                        <p>Länge: ${item.duration || 0}s</p>
                    </div>
                    <div class="item-actions">
                        ${index > 0 ? `<button class="btn btn-up" onclick="moveUp(${index})">▲</button>` : ''}
                        ${index < playlistItems.length - 1 ? `<button class="btn btn-down" onclick="moveDown(${index})">▼</button>` : ''}
                        <button class="btn btn-delete" onclick="deleteItem(${index})">✕</button>
                    </div>
                `;
                
                // Drag & Drop Events
                li.addEventListener('dragstart', (e) => dragStart(e, index));
                li.addEventListener('dragover', dragOver);
                li.addEventListener('drop', (e) => drop(e, index));
                li.addEventListener('dragend', dragEnd);
                
                list.appendChild(li);
            });
        }

        function dragStart(e, index) {
            draggedIndex = index;
            e.target.closest('.playlist-item').classList.add('dragging');
        }

        function dragOver(e) {
            e.preventDefault();
            const item = e.target.closest('.playlist-item');
            if (item && item !== e.target) {
                item.classList.add('drag-over');
            }
        }

        function drop(e, targetIndex) {
            e.preventDefault();
            
            if (draggedIndex !== targetIndex && draggedIndex !== -1) {
                const [draggedItem] = playlistItems.splice(draggedIndex, 1);
                playlistItems.splice(targetIndex, 0, draggedItem);
                renderPlaylist();
            }
        }

        function dragEnd(e) {
            document.querySelectorAll('.playlist-item').forEach(item => {
                item.classList.remove('dragging', 'drag-over');
            });
        }

        function moveUp(index) {
            if (index > 0) {
                [playlistItems[index], playlistItems[index - 1]] = [playlistItems[index - 1], playlistItems[index]];
                renderPlaylist();
            }
        }

        function moveDown(index) {
            if (index < playlistItems.length - 1) {
                [playlistItems[index], playlistItems[index + 1]] = [playlistItems[index + 1], playlistItems[index]];
                renderPlaylist();
            }
        }

        function deleteItem(index) {
            if (confirm(`Löschen: ${playlistItems[index].name}?`)) {
                playlistItems.splice(index, 1);
                renderPlaylist();
            }
        }

        async function savePlaylist() {
            try {
                document.getElementById('status').innerHTML = 'Speichern...';
                document.getElementById('status').style.display = 'block';
                
                const response = await fetch('/api/playout/updateplaylist', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ items: playlistItems })
                });
                
                if (response.ok) {
                    document.getElementById('status').innerHTML = '✓ Playlist gespeichert!';
                    setTimeout(() => closeEditor(), 1500);
                } else {
                    document.getElementById('status').innerHTML = '❌ Speichern fehlgeschlagen: ' + response.status;
                }
            } catch (error) {
                document.getElementById('status').innerHTML = '❌ Fehler: ' + error.message;
            }
        }

        function closeEditor() {
            window.history.back();
        }

        function escapeHtml(text) {
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }

        // Playlist beim Laden
        loadPlaylist();
    </script>
</body>
</html>
